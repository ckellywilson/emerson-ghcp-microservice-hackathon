{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NotificationService": {
    "DefaultPageSize": 20,
    "MaxPageSize": 100
  },
  "ServiceBus": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "InboundTopic": "contoso.domain.entity-changed.v1",
    "OutboundTopic": "notification.read-state-changed.v1"
  },
  "IntegrationEndpoints": {
    "MonolithAclIngressPath": "/acl/monolith/entity-changed",
    "CanonicalIngressPath": "/api/v1/events/entity-changed"
  }
}
