{
    "version": "0.2.0",
    "configurations": [
        {
            // Use IntelliSense to find out which attributes exist for C# debugging
            // Use hover for the description of the existing attributes
            // For further information visit https://github.com/dotnet/vscode-csharp/blob/main/debugger-launchjson.md.
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "debug-build-monolith",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/monolith/ContosoUniversity.Web/bin/Debug/net8.0/ContosoUniversity.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/monolith/ContosoUniversity.Web",
            "stopAtEntry": false,
            // Enable launching a web browser when ASP.NET Core starts. For more information: https://aka.ms/VSCode-CS-LaunchJson-WebBrowser
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:52380"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Launch Monolith Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "debug-build-monolith",
            "program": "${workspaceFolder}/monolith/ContosoUniversity.Web/bin/Debug/net8.0/ContosoUniversity.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/monolith/ContosoUniversity.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5300"
            }
        },
        {
            "name": ".NET Launch StudentService API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "debug-build-studentservice",
            "program": "${workspaceFolder}/services/StudentService/src/StudentService.Api/bin/Debug/net8.0/StudentService.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/services/StudentService/src/StudentService.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5201"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
        {
            "name": "Debug Monolith + StudentService",
            "configurations": [
                ".NET Launch Monolith Web",
                ".NET Launch StudentService API"
            ],
            "stopAll": true
        }
    ]
}